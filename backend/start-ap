#!/system/bin/sh

# VirtualAP engine
# Copyright (c) 2026 ravindu644
#
# Creates a virtual AP (ap0) on the phone's WiFi chip with a static gateway
# IP, DHCP+DNS via dnsmasq, and a selectable upstream. Successor of
# Ubuntu-Chroot's start-hotspot, modernized:
#   - upstream "auto": reads netd's default-network rule instead of asking
#   - pinned rule priorities (old unpinned rules could land below netd's
#     "32000: from all unreachable" and never match)
#   - interface-less MASQUERADE (survives upstream changes)
#   - dnsmasq instead of EOL ISC dhcpd; DNS served to clients too
#   - 5GHz channel-following (phone chips usually require same-channel
#     concurrency with the STA connection; DFS channels can't beacon)
#
# Binary split (hard rule): wireless ops (iw/hostapd/dnsmasq) run inside the
# Alpine chroot - many phones ship no iw binary. Routing and firewall use the
# Android side: /system/bin/ip and /system/bin/iptables.

BASE_DIR="/data/local/virtualap"
CHROOT_PATH="${BASE_DIR}/rootfs"
HOLDER_PID_FILE="${BASE_DIR}/holder.pid"
CONF_FILE="${BASE_DIR}/ap.conf"
STATE_FILE="${BASE_DIR}/run.state"
LOG_FILE="${BASE_DIR}/logs/ap.log"

IP="/system/bin/ip"
IPT="/system/bin/iptables"

# Network constants
AP_IFACE="ap0"
IP_GW="192.168.42.1"
IP_NET=""
IP_BEGIN=""
IP_END=""

# Pinned rule priorities. Above netd's whole range (10000+) so they always
# win, in their own block clear of Droidspaces' 6090-6100.
PRIO_TO_SUBNET=7000   # to 192.168.42.0/24 lookup main   (return path)
PRIO_FROM_AP=7010     # from all iif ap0 lookup <table>  (upstream steering)

# Android's fixed local_network routing table (RouteController::ROUTE_TABLE_LOCAL_NETWORK,
# constant since Android 5). We mirror the AP subnet into this table so that reply packets
# from containers (src 172.28.0.0/16) reach VirtualAP clients: Droidspaces installs rule
# 6095 "from 172.28.0.0/16 lookup local_network", which runs before 6100 (the WAN uplink
# rule). Without a route here, 6095 misses, 6100 grabs the reply, and it leaks out WAN.
ANDROID_LOCAL_NETWORK_TABLE=97

# Defaults (overridden by ap.conf, then by CLI flags)
PHY_IFACE="wlan0"
UPSTREAM="auto"
SSID=""
PASSWORD=""
BAND="2"
CHANNEL=""
DNS_SERVERS=""
HIDDEN="0"

SCRIPT_NAME="$(basename "$0")"
# vap.sh lives next to this script (both run from the app's files dir,
# re-extracted from APK assets every launch - see Backend.kt), not in BASE_DIR.
VAP_SH="$(dirname "$0")/vap.sh"

# --- Busybox resolution ---
if [ -x "$BASE_DIR/bin/busybox" ]; then
    export BUSYBOX="$BASE_DIR/bin/busybox"
elif command -v busybox >/dev/null 2>&1; then
    export BUSYBOX="busybox"
else
    echo "[ERROR] No busybox found. Aborting." >&2
    exit 1
fi

mkdir -p "$BASE_DIR/logs"

log()   { echo "$1";          echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"; }
warn()  { echo "[WARN] $1";   echo "[$(date '+%Y-%m-%d %H:%M:%S')] [WARN] $1" >> "$LOG_FILE"; }
error() { echo "[ERROR] $1";  echo "[$(date '+%Y-%m-%d %H:%M:%S')] [ERROR] $1" >> "$LOG_FILE"; }

# --- Namespace plumbing (same pattern as vap.sh) ---

_get_ns_flags() {
    local flags_file="$HOLDER_PID_FILE.flags"
    [ ! -f "$flags_file" ] && { echo "-m"; return; }
    local long_flags short_flags
    long_flags=$(cat "$flags_file")
    [ -z "$long_flags" ] && { echo "-m"; return; }
    for flag in $long_flags; do
        case "$flag" in
            --mount) short_flags="$short_flags -m" ;;
            --uts)   short_flags="$short_flags -u" ;;
            --ipc)   short_flags="$short_flags -i" ;;
            --pid)   short_flags="$short_flags -p" ;;
        esac
    done
    [ -z "$short_flags" ] && { echo "-m"; return; }
    echo "$short_flags"
}

_execute_in_ns() {
    local holder_pid
    if [ -f "$HOLDER_PID_FILE" ] && kill -0 "$(cat "$HOLDER_PID_FILE")" 2>/dev/null; then
        holder_pid=$(cat "$HOLDER_PID_FILE")
        "${BUSYBOX}" nsenter --target "$holder_pid" $(_get_ns_flags) -- "$@"
    else
        "$@"
    fi
}

run_in_ns() { _execute_in_ns "$@"; }

run_in_chroot() {
    _execute_in_ns chroot "$CHROOT_PATH" /bin/sh -c "PATH=/usr/sbin:/usr/bin:/sbin:/bin; export TMPDIR=/tmp; $*"
}

# --- Config persistence ---

load_conf() {
    [ -f "$CONF_FILE" ] && . "$CONF_FILE"
}

# Single-quote values for sourcing: a password containing " or $ must not
# break (or worse, execute inside) the conf file.
sq() { printf "%s" "$1" | sed "s/'/'\\\\''/g"; }

save_conf() {
    cat > "$CONF_FILE" <<EOF
PHY_IFACE='$(sq "$PHY_IFACE")'
UPSTREAM='$(sq "$UPSTREAM")'
SSID='$(sq "$SSID")'
PASSWORD='$(sq "$PASSWORD")'
BAND='$(sq "$BAND")'
CHANNEL='$(sq "$CHANNEL")'
IP_GW='$(sq "$IP_GW")'
DNS_SERVERS='$(sq "$DNS_SERVERS")'
HIDDEN='$(sq "$HIDDEN")'
EOF
}

# --- Upstream resolution ---

detect_auto_table() {
    # netd's default-network rule is the kernel's ground truth for "which
    # network has internet right now":  from all fwmark 0x0/0xffff iif lo
    # lookup <table>.  Rules print sorted by priority, so the first match
    # wins; uidrange variants are per-app VPN rules - skip them.
    "$IP" rule show 2>/dev/null \
        | grep "fwmark 0x0/0xffff iif lo" \
        | grep -v uidrange \
        | head -n1 \
        | sed -n 's/.*lookup \([^ ]*\).*$/\1/p'
}

table_oif() {
    # default route's outgoing interface in a given table
    "$IP" route show table "$1" 2>/dev/null \
        | grep '^default' | head -n1 \
        | sed -n 's/.*dev \([^ ]*\).*/\1/p'
}

resolve_iface_table() {
    # Per-interface table: netd names tables after interfaces
    # (/data/misc/net/rt_tables), so a name lookup usually just works -
    # including for wg0 from the official WireGuard app (kernel backend).
    local iface="$1"
    if "$IP" route show table "$iface" 2>/dev/null | grep -q .; then
        echo "$iface"; return 0
    fi
    # Fallback: scan all tables for routes through this interface
    local tbl
    tbl=$("$IP" route show table all 2>/dev/null \
        | grep " dev $iface " | sed -n 's/.*table \([0-9]*\).*/\1/p' | head -n1)
    if [ -n "$tbl" ]; then
        echo "$tbl"; return 0
    fi
    # Last resort: the interface routes via main (sideloaded ethernet etc.)
    echo "main"
}

resolve_upstream() {
    # Sets UPSTREAM_TABLE and UPSTREAM_IFACE_RESOLVED
    if [ "$UPSTREAM" = "auto" ]; then
        UPSTREAM_TABLE=$(detect_auto_table)
        if [ -z "$UPSTREAM_TABLE" ]; then
            error "Could not auto-detect the upstream network (no netd default-network rule)."
            error "Select an upstream interface explicitly with -o <iface>."
            return 1
        fi
        UPSTREAM_IFACE_RESOLVED=$(table_oif "$UPSTREAM_TABLE")
        log "Auto upstream: table $UPSTREAM_TABLE${UPSTREAM_IFACE_RESOLVED:+ ($UPSTREAM_IFACE_RESOLVED)}"
    else
        if [ ! -d "/sys/class/net/$UPSTREAM" ]; then
            error "Upstream interface '$UPSTREAM' does not exist."
            return 1
        fi
        UPSTREAM_TABLE=$(resolve_iface_table "$UPSTREAM")
        UPSTREAM_IFACE_RESOLVED="$UPSTREAM"
        log "Upstream: $UPSTREAM (table $UPSTREAM_TABLE)"
    fi
    return 0
}

# --- Wireless helpers (chroot iw) ---

sta_channel() {
    # Current channel of the STA connection, empty if not connected
    run_in_chroot "iw dev $PHY_IFACE info" 2>/dev/null \
        | sed -n 's/.*channel \([0-9]*\).*/\1/p' | head -n1
}

reg_country() {
    run_in_chroot "iw reg get" 2>/dev/null \
        | sed -n 's/^country \([A-Z][A-Z]\):.*/\1/p' | head -n1
}

is_dfs_channel() {
    # 5GHz DFS range: beaconing needs radar detection - phone chips refuse
    [ "$1" -ge 52 ] 2>/dev/null && [ "$1" -le 144 ] 2>/dev/null
}

pick_channel() {
    # Same-channel concurrency: most phone WiFi chips can only beacon on the
    # channel the STA is already using. Follow it whenever it fits the
    # requested band; fall back gracefully otherwise.
    local sta_ch
    sta_ch=$(sta_channel)

    if [ "$BAND" = "5" ]; then
        if [ -n "$sta_ch" ] && [ "$sta_ch" -ge 36 ] 2>/dev/null; then
            if is_dfs_channel "$sta_ch"; then
                warn "STA is on 5GHz DFS channel $sta_ch - AP cannot beacon there. Falling back to 2.4GHz."
                BAND="2"; CHANNEL="${CHANNEL:-6}"
            else
                if [ -n "$CHANNEL" ] && [ "$CHANNEL" != "$sta_ch" ]; then
                    warn "Requested channel $CHANNEL but STA is on $sta_ch - using $sta_ch (same-channel concurrency)."
                fi
                CHANNEL="$sta_ch"
            fi
        elif [ -n "$sta_ch" ]; then
            warn "STA is on 2.4GHz (channel $sta_ch) - 5GHz AP would need different-band concurrency."
            if [ -z "$CHANNEL" ]; then
                warn "Trying 5GHz channel 36; if the AP fails to start, use band 2."
                CHANNEL="36"
            fi
        else
            # No STA connection (mobile-data upstream) - radio is free
            CHANNEL="${CHANNEL:-36}"
        fi
    else
        if [ -n "$sta_ch" ] && [ "$sta_ch" -le 14 ] 2>/dev/null; then
            [ -n "$CHANNEL" ] && [ "$CHANNEL" != "$sta_ch" ] && \
                warn "Requested channel $CHANNEL but STA is on $sta_ch - using $sta_ch (same-channel concurrency)."
            CHANNEL="$sta_ch"
        else
            CHANNEL="${CHANNEL:-6}"
        fi
    fi
}

# --- Subnet helper ---

calculate_subnet() {
    local ip="$1"
    # Match standard IPv4 format: A.B.C.D where octets are 0-255
    if ! echo "$ip" | grep -Eq '^(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$'; then
        return 1
    fi

    # Validate that last octet is not 0 or 255
    local last_octet
    last_octet=$(echo "$ip" | cut -d. -f4)
    if [ "$last_octet" -eq 0 ] || [ "$last_octet" -eq 255 ]; then
        return 1
    fi

    local base
    base=$(echo "$ip" | cut -d. -f1-3)
    IP_GW="$ip"
    IP_NET="$base.0/24"
    IP_BEGIN="$base.10"
    IP_END="$base.50"
    return 0
}

# --- Prerequisites ---

check_prerequisites() {
    [ -x "$IP" ] || { error "$IP not found"; return 1; }
    [ -x "$IPT" ] || { error "$IPT not found"; return 1; }
    run_in_chroot "command -v iw" >/dev/null 2>&1 || { error "iw not found in chroot"; return 1; }
    run_in_chroot "command -v hostapd" >/dev/null 2>&1 || { error "hostapd not found in chroot"; return 1; }
    run_in_chroot "command -v dnsmasq" >/dev/null 2>&1 || { error "dnsmasq not found in chroot"; return 1; }
    return 0
}

# --- Teardown (mirrors setup exactly; every step tolerant) ---

teardown() {
    log "Bringing down $AP_IFACE and reverting settings..."

    # Stop services via their pidfiles
    run_in_chroot "[ -f /run/hostapd.pid ] && kill \$(cat /run/hostapd.pid) 2>/dev/null; \
                   [ -f /run/dnsmasq.pid ] && kill \$(cat /run/dnsmasq.pid) 2>/dev/null; \
                   rm -f /run/hostapd.pid /run/dnsmasq.pid /run/hostapd.conf /run/dnsmasq.conf" 2>/dev/null || true

    # Policy rules - delete by pinned priority until none remain
    while "$IP" rule del pref "$PRIO_FROM_AP" 2>/dev/null; do :; done
    while "$IP" rule del pref "$PRIO_TO_SUBNET" 2>/dev/null; do :; done

    # Firewall (mirror of setup inserts)
    "$IPT" -t nat -D POSTROUTING -s "$IP_NET" ! -d "$IP_NET" -j MASQUERADE 2>/dev/null || true
    "$IPT" -D FORWARD -i "$AP_IFACE" -j ACCEPT 2>/dev/null || true
    "$IPT" -D FORWARD -o "$AP_IFACE" -j ACCEPT 2>/dev/null || true

    "$IP" route del "$IP_NET" dev "$AP_IFACE" table main 2>/dev/null || true
    "$IP" route del "$IP_NET" dev "$AP_IFACE" table "$ANDROID_LOCAL_NETWORK_TABLE" 2>/dev/null || true

    # Restore ip_forward only if we were the ones who enabled it
    if [ -f "$STATE_FILE" ]; then
        local prev_fwd
        prev_fwd=$(sed -n 's/^prev_ip_forward=//p' "$STATE_FILE")
        [ "$prev_fwd" = "0" ] && echo 0 > /proc/sys/net/ipv4/ip_forward 2>/dev/null
    fi

    # Delete the virtual interface (chroot iw, host ip as fallback)
    run_in_chroot "iw dev $AP_IFACE del" 2>/dev/null \
        || "$IP" link del "$AP_IFACE" 2>/dev/null || true

    rm -f "$STATE_FILE"
    log "AP stopped, cleanup completed."
}

# --- Setup ---

config_network() {
    log "Creating virtual AP interface '$AP_IFACE' on $PHY_IFACE..."

    run_in_chroot "iw dev $AP_IFACE del" 2>/dev/null || true

    if ! run_in_chroot "iw dev $PHY_IFACE interface add $AP_IFACE type __ap"; then
        error "Failed to create $AP_IFACE - chip/driver may not support AP mode."
        return 1
    fi
    run_in_chroot "iw dev $AP_IFACE info" >/dev/null 2>&1 || {
        error "$AP_IFACE was not created successfully"; return 1; }

    log "Configuring gateway address $IP_GW..."
    "$IP" link set "$AP_IFACE" down 2>/dev/null
    "$IP" addr flush dev "$AP_IFACE" 2>/dev/null
    "$IP" addr add "$IP_GW/24" dev "$AP_IFACE" || { error "Failed to assign $IP_GW"; return 1; }
    "$IP" link set "$AP_IFACE" up || { error "Failed to bring up $AP_IFACE"; return 1; }

    local prev_fwd
    prev_fwd=$(cat /proc/sys/net/ipv4/ip_forward 2>/dev/null)
    echo 1 > /proc/sys/net/ipv4/ip_forward || { error "Failed to enable IP forwarding"; return 1; }

    log "Installing routes and policy rules..."

    # Connected route in main ("replace" - restarts must not stack duplicates)
    "$IP" route replace "$IP_NET" dev "$AP_IFACE" src "$IP_GW" proto static scope link table main \
        || { error "Failed to add subnet route to main"; return 1; }

    # Mirror route in local_network table (97) so container reply packets
    # (src 172.28.0.0/16) reach VirtualAP clients via Droidspaces rule 6095.
    "$IP" route replace "$IP_NET" dev "$AP_IFACE" src "$IP_GW" proto static scope link \
        table "$ANDROID_LOCAL_NETWORK_TABLE" 2>/dev/null \
        || warn "Could not add subnet route to local_network table ($ANDROID_LOCAL_NETWORK_TABLE) - port forwards from containers may not work"

    # Return path: replies/forwards TO the AP subnet resolve via main, above
    # every netd rule (incl. VPN catch-alls)
    "$IP" rule add from all to "$IP_NET" lookup main pref "$PRIO_TO_SUBNET" 2>/dev/null \
        || warn "to-subnet rule already present"

    # Upstream steering: everything FROM the AP clients goes to the selected
    # network's table
    "$IP" rule add from all iif "$AP_IFACE" lookup "$UPSTREAM_TABLE" pref "$PRIO_FROM_AP" \
        || { error "Failed to add upstream steering rule (table $UPSTREAM_TABLE)"; return 1; }

    # Firewall: scope to ap0 only; interface-less MASQUERADE survives
    # upstream changes (Docker/LXC style)
    "$IPT" -I FORWARD 1 -i "$AP_IFACE" -j ACCEPT || { error "FORWARD -i insert failed"; return 1; }
    "$IPT" -I FORWARD 1 -o "$AP_IFACE" -j ACCEPT || { error "FORWARD -o insert failed"; return 1; }
    "$IPT" -t nat -I POSTROUTING 1 -s "$IP_NET" ! -d "$IP_NET" -j MASQUERADE \
        || { error "MASQUERADE insert failed"; return 1; }

    # Record state for exact teardown + status
    cat > "$STATE_FILE" <<EOF
upstream=$UPSTREAM
upstream_table=$UPSTREAM_TABLE
upstream_iface=$UPSTREAM_IFACE_RESOLVED
band=$BAND
channel=$CHANNEL
ssid=$SSID
gateway=$IP_GW
dns_servers=$DNS_SERVERS
prev_ip_forward=$prev_fwd
started=$(date '+%Y-%m-%d %H:%M:%S')
EOF

    log "Network configuration completed."
    return 0
}

start_services() {
    log "Generating service configs (band ${BAND}GHz, channel $CHANNEL)..."

    local country hw_mode extra
    country=$(reg_country)
    if [ "$BAND" = "5" ]; then
        hw_mode="a"
        extra="ieee80211n=1
ieee80211ac=1"
    else
        hw_mode="g"
        extra="ieee80211n=1"
    fi

    run_in_chroot "cat > /run/hostapd.conf" <<EOF
interface=$AP_IFACE
driver=nl80211
ctrl_interface=/run/hostapd
ssid=$SSID
hw_mode=$hw_mode
channel=$CHANNEL
$extra
${country:+country_code=$country}
${country:+ieee80211d=1}
wpa=2
wpa_passphrase=$PASSWORD
wpa_key_mgmt=WPA-PSK
rsn_pairwise=CCMP
ignore_broadcast_ssid=$HIDDEN
EOF

    local dns_config=""
    if [ -n "$DNS_SERVERS" ]; then
        dns_config="no-resolv"
        local old_ifs="$IFS"
        IFS=","
        for dns in $DNS_SERVERS; do
            local clean_dns
            clean_dns=$(echo "$dns" | tr -d '[:space:]')
            if [ -n "$clean_dns" ]; then
                dns_config="$dns_config
server=$clean_dns"
            fi
        done
        IFS="$old_ifs"
    else
        dns_config="resolv-file=/etc/resolv.conf"
    fi

    run_in_chroot "cat > /run/dnsmasq.conf" <<EOF
interface=$AP_IFACE
bind-interfaces
except-interface=lo
listen-address=$IP_GW
dhcp-range=$IP_BEGIN,$IP_END,12h
dhcp-option=option:router,$IP_GW
dhcp-option=option:dns-server,$IP_GW
dhcp-leasefile=/run/dnsmasq.leases
$dns_config
no-hosts
pid-file=/run/dnsmasq.pid
user=root
EOF

    log "Starting hostapd..."
    if ! run_in_chroot "hostapd -B -P /run/hostapd.pid /run/hostapd.conf"; then
        error "hostapd failed to start (check band/channel - try band 2)."
        return 1
    fi
    sleep 2
    run_in_chroot "[ -f /run/hostapd.pid ] && kill -0 \$(cat /run/hostapd.pid)" 2>/dev/null || {
        error "hostapd is not running after start"; return 1; }
    log "hostapd running (PID $(run_in_chroot 'cat /run/hostapd.pid' 2>/dev/null))"

    log "Starting dnsmasq..."
    if ! run_in_chroot "dnsmasq -C /run/dnsmasq.conf"; then
        error "dnsmasq failed to start"
        return 1
    fi
    sleep 1
    run_in_chroot "[ -f /run/dnsmasq.pid ] && kill -0 \$(cat /run/dnsmasq.pid)" 2>/dev/null || {
        error "dnsmasq is not running after start"; return 1; }
    log "dnsmasq running (PID $(run_in_chroot 'cat /run/dnsmasq.pid' 2>/dev/null))"

    return 0
}

# --- Subcommands ---

cmd_start() {
    [ -z "$SSID" ] && { error "SSID not set (use -s or save a config first)"; exit 1; }
    if [ "$(printf %s "$PASSWORD" | wc -c)" -lt 8 ]; then
        error "Password must be at least 8 characters."; exit 1
    fi

    # Validate channel compatibility with selected band
    if [ -n "$CHANNEL" ]; then
        case "$CHANNEL" in
            *[!0-9]*)
                warn "Channel '$CHANNEL' is not a valid number. Resetting to auto."
                CHANNEL=""
                ;;
            *)
                if [ "$BAND" = "5" ]; then
                    if [ "$CHANNEL" -lt 36 ]; then
                        warn "Channel $CHANNEL is invalid for 5GHz band. Resetting to auto."
                        CHANNEL=""
                    fi
                else
                    if [ "$CHANNEL" -lt 1 ] || [ "$CHANNEL" -gt 14 ]; then
                        warn "Channel $CHANNEL is invalid for 2.4GHz band. Resetting to auto."
                        CHANNEL=""
                    fi
                fi
                ;;
        esac
    fi

    # Persist settings now, before pick_channel mutates BAND/CHANNEL and
    # before anything can fail - a failed attempt must not lose the config.
    save_conf

    # Restart semantics: tear down any previous AP, then recycle the chroot.
    # The namespace holder is the PID-ns init but never reaps reparented
    # children (busybox sleep has no wait loop), so dead hostapd/dnsmasq pile
    # up as zombies under it - a fresh namespace per AP session keeps the
    # process table clean.
    [ -f "$STATE_FILE" ] && { log "Existing AP state found - restarting..."; teardown; }
    sh "$VAP_SH" stop -s >/dev/null 2>&1
    sh "$VAP_SH" start -s || { error "Failed to start chroot environment"; exit 1; }

    check_prerequisites || exit 1

    resolve_upstream || exit 1
    pick_channel

    trap 'full_stop; exit 1' INT TERM

    if ! config_network; then
        full_stop
        exit 1
    fi

    if ! start_services; then
        full_stop
        exit 1
    fi

    log "VirtualAP is ACTIVE!"
    log "  SSID    : $SSID (${BAND}GHz, channel $CHANNEL)"
    log "  Gateway : $IP_GW (static - never changes)"
    log "  Upstream: ${UPSTREAM_IFACE_RESOLVED:-$UPSTREAM} (table $UPSTREAM_TABLE)"
}

# Full teardown: AP rules/services first, then the whole chroot. The chroot
# exists only to serve the AP - killing the PID-namespace holder makes the
# kernel reap every process in the namespace, including the zombies that
# 'busybox sleep' (the ns init) never wait()ed for.
full_stop() {
    teardown
    sh "$VAP_SH" stop -s >/dev/null 2>&1
    log "Chroot environment stopped."
}

cmd_stop() {
    full_stop
}

cmd_status() {
    local running=0 hostapd_state="dead" dnsmasq_state="dead" clients=0

    if [ -f "$STATE_FILE" ]; then
        run_in_chroot "[ -f /run/hostapd.pid ] && kill -0 \$(cat /run/hostapd.pid)" 2>/dev/null && hostapd_state="running"
        run_in_chroot "[ -f /run/dnsmasq.pid ] && kill -0 \$(cat /run/dnsmasq.pid)" 2>/dev/null && dnsmasq_state="running"
        [ "$hostapd_state" = "running" ] && running=1
        clients=$(run_in_chroot "iw dev $AP_IFACE station dump" 2>/dev/null | grep -c '^Station')
    fi

    echo "running=$running"
    echo "hostapd=$hostapd_state"
    echo "dnsmasq=$dnsmasq_state"
    echo "gateway=$IP_GW"
    echo "clients=$clients"
    if [ -f "$STATE_FILE" ]; then
        grep -E '^(ssid|band|channel|upstream|upstream_table|upstream_iface|gateway|dns_servers|started)=' "$STATE_FILE"
    fi
}

cmd_leases() {
    run_in_chroot "cat /run/dnsmasq.leases" 2>/dev/null
}

cmd_interfaces() {
    # Candidate upstream interfaces as "name:ip" lines for the WebUI.
    # ap0 and lo are never valid upstreams.
    local name addr
    for path in /sys/class/net/*; do
        name=$(basename "$path")
        case "$name" in
            lo|"$AP_IFACE") continue ;;
        esac
        addr=$("$IP" -4 -o addr show dev "$name" 2>/dev/null \
            | sed -n 's/.*inet \([0-9.]*\).*/\1/p' | head -n1)
        echo "$name:${addr:-no-ip}"
    done
}

# --- Main ---

if [ "$(id -u)" -ne 0 ]; then
    error "This script must be run as root."; exit 1
fi

print_usage() {
    echo "Usage: $SCRIPT_NAME <start|stop|status|leases|interfaces> [options]"
    echo ""
    echo "start options:"
    echo "  -s <SSID>      AP name"
    echo "  -p <password>  AP password (min 8 chars)"
    echo "  -o <iface>     Upstream interface, or 'auto' (default: auto)"
    echo "  -b <band>      2 = 2.4GHz (default), 5 = 5GHz"
    echo "  -c <channel>   Channel (auto-picked / STA-followed when omitted)"
    echo "  -g <gateway>   Custom gateway IP (default: 192.168.42.1)"
    echo "  -d <dns>       Comma-separated list of upstream DNS servers"
    echo "  -w <iface>     Physical WiFi interface (default: wlan0)"
    echo "  -H <0|1>       Hide SSID (0 = visible [default], 1 = hidden)"
    echo ""
    echo "Saved settings in $CONF_FILE are reused when flags are omitted."
}

COMMAND="$1"
[ -n "$COMMAND" ] && shift

# Saved config provides defaults; CLI flags override
load_conf

while getopts "s:p:o:b:c:w:g:d:H:h" opt 2>/dev/null; do
    case $opt in
        s) SSID="$OPTARG" ;;
        p) PASSWORD="$OPTARG" ;;
        o) UPSTREAM="$OPTARG" ;;
        b) BAND="$OPTARG" ;;
        c) CHANNEL="$OPTARG" ;;
        w) PHY_IFACE="$OPTARG" ;;
        g) IP_GW="$OPTARG" ;;
        d) DNS_SERVERS="$OPTARG" ;;
        H) HIDDEN="$OPTARG" ;;
        h) print_usage; exit 0 ;;
        *) print_usage; exit 1 ;;
    esac
done

if ! calculate_subnet "$IP_GW"; then
    error "Invalid gateway IP address: '$IP_GW'"
    exit 1
fi

case "$COMMAND" in
    start)      cmd_start ;;
    stop)       cmd_stop ;;
    status)     cmd_status ;;
    leases)     cmd_leases ;;
    interfaces) cmd_interfaces ;;
    -h|--help|help|"") print_usage; exit 0 ;;
    *) error "Unknown command: $COMMAND"; print_usage; exit 1 ;;
esac
